@model PHA.Models.User
@using PHA.Controllers
@{
    Layout = "_Layout";
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>
</head>

<body>
    <form action="Login" method="post" class="body authen-container" role="form">
		<div class="authen-form">
			<div class="auth-form__item authen-form__header">
                <h3>PHA_LOGIN</h3>
            </div>

			<div class="form-group">
                <label for="Username" class="control-label">Username</label>
				<input type="text" class="form-control" name="username" required>
			</div>
			<div class="form-group">
                <label for="Password" class="control-label">Password</label>
				<input id="password-field" type="password" class="form-control" name="password" required>
				@* <span toggle="#password-field" class="fa fa-fw fa-eye field-icon toggle-password"></span> *@
			</div>

			<div class="form-group">
				<button type="submit" class="form-control btn btn-primary submit px-3">Log In</button>
			</div>
			<div class="form-group d-md-flex">
				<div class="w-50">
					<label class="checkbox-wrap checkbox-primary">
						Remember Me
						<input type="checkbox" checked>
						<span class="checkmark"></span>
					</label>
				</div>
				<div class="w-50 text-md-right">
					<a href="Forgot" style="color: #fff">Forgot Password</a>
				</div>
			</div>
		</div>
	</form>
</body>
</html>